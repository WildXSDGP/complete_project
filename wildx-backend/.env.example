# Server
PORT=8080
NODE_ENV=development

# Neon PostgreSQL (used by ALL modules)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/wildxdb?sslmode=require

# JWT (for email/password auth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# CORS
ALLOWED_ORIGIN=*
